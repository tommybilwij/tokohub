{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/refs/heads/v2/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "TokoHub",
  "version": "0.1.0",
  "identifier": "com.tokohub.desktop",
  "build": {
    "frontendDist": "./frontend-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "http://127.0.0.1:5000",
        "title": "TokoHub",
        "width": 1280,
        "height": 800,
        "visible": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/tokohub-server*",
      "binaries/_internal"
    ],
    "targets": ["app", "dmg", "msi", "nsis"],
    "macOS": {
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null,
      "infoPlist": "Info.plist"
    }
  }
}
